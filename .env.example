# Signal CLI REST API base URL (host:port, no scheme)
SIGNAL_CLI_URL=localhost:8080

# Phone number registered with signal-cli (E.164 format)
SIGNAL_PHONE_NUMBER=+15551234567

# Telegram bot token from @BotFather
TELEGRAM_TOKEN=123456789:AAABBBCCCDDDEEEFFFGGG

# Wuzapi base URL (host:port, no scheme)
WUZAPI_URL=localhost:8080

# Wuzapi user token (set when creating the wuzapi user)
WUZAPI_TOKEN=changeme

# Wuzapi admin/infra tokens (passed to the wuzapi container)
WUZAPI_ADMIN_TOKEN=changeme-admin
WUZAPI_GLOBAL_ENCRYPTION_KEY=changeme-encryption-key
WUZAPI_GLOBAL_HMAC_KEY=changeme-hmac-key

# Redis connection URL
REDIS_URL=redis://localhost:6379

# API key required for /send and /notify endpoints (X-API-Key header)
API_KEY=changeme-api-key

# Signal recipient for /notify (group ID takes precedence over phone)
NOTIFY_SIGNAL_GROUP_ID=group.AAABBBCCC=
NOTIFY_SIGNAL_PHONE=+15551234567

# WhatsApp number (E.164) or JID for /notify
NOTIFY_WHATSAPP_NUMBER=+15551234567

# Telegram chat ID (integer) for /notify
NOTIFY_TELEGRAM_CHAT_ID=903286064
